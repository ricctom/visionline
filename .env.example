# Base de datos SQLite
# En Railway: file:/app/data/visionline.db  (con volumen montado en /app/data)
# En local:   file:./prisma/dev.db
DATABASE_URL="file:./prisma/dev.db"

# Clave secreta para JWT (cambiá esto en producción)
JWT_SECRET=cambia_esto_por_una_clave_segura_y_larga

# Entorno
NODE_ENV=development
PORT=3000
